{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run ZeroPoint Dev",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "(https?://localhost:\\d+)",
        "uriFormat": "%s"
      }
    }
  ]
}
